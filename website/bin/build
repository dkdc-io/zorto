#!/usr/bin/env bash
set -euo pipefail
WEBSITE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
REPO_ROOT="$(cd "$WEBSITE_DIR/.." && pwd)"

# sync website executable-code dependencies
cd "$WEBSITE_DIR"
uv sync

# Netlify installs the released zorto binary before running this script. Use it
# there so deploys stay fast and do not compile the repo.
cd "$REPO_ROOT"
if [[ "${NETLIFY:-}" == "true" ]]; then
  if ! command -v zorto >/dev/null 2>&1; then
    echo "error: zorto CLI not found on PATH; install it before running website/bin/build on Netlify" >&2
    exit 127
  fi
  VIRTUAL_ENV="$WEBSITE_DIR/.venv" zorto --root website --sandbox . build "$@"
else
  # Local builds use the current Rust workspace CLI from repo root.
  VIRTUAL_ENV="$WEBSITE_DIR/.venv" cargo run -p zorto -- --root website --sandbox . build "$@"
fi
